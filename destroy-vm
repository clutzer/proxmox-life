#!/usr/bin/env python3
import argparse
import subprocess
import sys
import json
import os

# --- Configuration ---
PROTECTED_FILE = "/etc/pve/protected-vms"

def run_command(cmd, error_msg=None, return_json=False):
    """Helper to run shell commands."""
    try:
        result = subprocess.run(cmd, shell=True, check=True, capture_output=True, text=True)
        if return_json:
            return json.loads(result.stdout)
        return result.stdout
    except subprocess.CalledProcessError as e:
        if error_msg:
            print(f"ERROR: {error_msg}")
            print(f"Details: {e.stderr}")
        return None

def get_protected_vmid_list():
    """Reads the protected VMIDs from the config file."""
    if not os.path.exists(PROTECTED_FILE):
        return []
    with open(PROTECTED_FILE, 'r') as f:
        # Read lines, strip whitespace, and ignore empty lines or comments
        return [line.strip() for line in f if line.strip() and not line.startswith('#')]

def get_vm_list():
    """Fetches a list of all VMs (excluding templates)."""
    resources = run_command("pvesh get /cluster/resources --output-format json", return_json=True)
    vms = [res for res in resources if res.get('type') == 'qemu' and not res.get('template')]
    return vms

def main():
    parser = argparse.ArgumentParser(description="Safely destroy a Proxmox VM.")
    parser.add_argument("vmid", nargs="?", help="The ID of the VM to destroy")
    args = parser.parse_args()

    protected_ids = get_protected_vmid_list()
    target_vmid = args.vmid

    # 1. Interactive Selection if VMID is missing
    if not target_vmid:
        vms = get_vm_list()
        if not vms:
            print("No VMs found to destroy.")
            sys.exit(0)

        print(f"{'VMID':<10} {'NAME':<20} {'STATUS':<10} {'PROTECTED':<10}")
        print("-" * 55)
        for vm in vms:
            vmid_str = str(vm['vmid'])
            is_protected = "YES" if vmid_str in protected_ids else "no"
            print(f"{vmid_str:<10} {vm['name']:<20} {vm['status']:<10} {is_protected:<10}")
        print("-" * 55)

        try:
            target_vmid = input("Enter the VMID to DESTROY (or Ctrl+C to cancel): ").strip()
        except KeyboardInterrupt:
            print("\nAborted.")
            sys.exit(0)

    # 2. Hard Block if VMID is Protected
    if str(target_vmid) in protected_ids:
        print(f"\nFATAL: VMID {target_vmid} is in the PROTECTED list ({PROTECTED_FILE}).")
        print("This VM cannot be destroyed via this script.")
        sys.exit(1)

    # 3. Standard Safety Checks (Template check, existence)
    vm_resources = run_command("pvesh get /cluster/resources --output-format json", return_json=True)
    vm_info = next((res for res in vm_resources if str(res.get('vmid')) == str(target_vmid)), None)

    if not vm_info:
        print(f"ERROR: VMID {target_vmid} not found.")
        sys.exit(1)
    
    if vm_info.get('template'):
        print(f"FATAL: VMID {target_vmid} is a Template. (Templates are implicitly protected).")
        sys.exit(1)

    # 4. Confirmation
    confirm = input(f"DANGER: Are you sure you want to permanently delete '{vm_info['name']}' ({target_vmid})? [y/N]: ")
    if confirm.lower() != 'y':
        print("Deletion canceled.")
        sys.exit(0)

    # 5. Execution
    print(f"--- [1/2] Stopping VM {target_vmid} (if running) ---")
    subprocess.run(f"qm stop {target_vmid}", shell=True, capture_output=True)

    print(f"--- [2/2] Purging VM {target_vmid} ---")
    run_command(f"qm destroy {target_vmid} --purge", f"Failed to destroy VM {target_vmid}.")

    print(f"\nSuccessfully destroyed VM {target_vmid}.")

if __name__ == "__main__":
    main()
