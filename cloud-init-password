#!/usr/bin/env python3

import hashlib
import secrets
import string
import getpass
import sys

def generate_cloud_init_hash():
    print("--- Cloud-Init Password Hash Generator (Python 3.13+ Compatible) ---")
    
    pwd = getpass.getpass("Enter password: ")
    confirm = getpass.getpass("Confirm password: ")

    if pwd != confirm:
        print("Error: Passwords do not match.")
        sys.exit(1)

    # Cloud-init (and Linux) expect SHA-512 hashes in the format:
    # $6$rounds=<rounds>$<salt>$<hash>
    # We will use a standard 16-character salt.
    alphabet = string.ascii_letters + string.digits + "./"
    salt = ''.join(secrets.choice(alphabet) for _ in range(16))
    
    # Generate the hash using crypt-style SHA-512 (SHA-crypt)
    # Note: Pure hashlib.sha512 isn't exactly the same as Unix 'crypt' SHA512.
    # For a "Zero Dependency" script on modern Python, we'll use a 
    # simple command-line call to 'openssl' which is guaranteed to be on Proxmox.
    
    import subprocess
    try:
        # This uses the system's OpenSSL to do the heavy lifting safely
        result = subprocess.check_output(
            ['openssl', 'passwd', '-6', '-salt', salt, pwd],
            universal_newlines=True
        ).strip()
        
        print("\nCopy the following string into your sa-user.yaml:")
        print("-" * 60)
        print(result)
        print("-" * 60)
    except FileNotFoundError:
        print("Error: 'openssl' command not found. Please install it or use an older Python.")

if __name__ == "__main__":
    generate_cloud_init_hash()
