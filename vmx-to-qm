#!/usr/bin/env python3
import os
import sys
import argparse
import subprocess
import tomllib
import shutil

CONFIG_PATH = os.path.expanduser("~/.config/vmx-to-qm")

def check_proxmox():
    if shutil.which('pveversion') is None:
        print("Error: This script must be run on a Proxmox node.")
        sys.exit(1)

def get_storage_type(storage_name):
    """Detects if storage is a Directory/NAS vs Block (LVM/ZFS)."""
    try:
        output = subprocess.check_output(['pvesm', 'status', '--storage', storage_name]).decode()
        if any(t in output.lower() for t in ['dir', 'nfs', 'cifs', 'gluster']):
            return 'directory'
    except:
        pass
    return 'block'

def parse_vmx(vmx_path):
    vmx_data = {}
    with open(vmx_path, 'r') as f:
        for line in f:
            if '=' in line:
                key, val = line.split('=', 1)
                vmx_data[key.strip().lower()] = val.strip().strip('"')
    
    vmx_dir = os.path.dirname(os.path.abspath(vmx_path))
    disks = []
    total_size = 0
    
    total_vcpus = int(vmx_data.get('numvcpus', 1))
    cores_per_socket = int(vmx_data.get('cpuid.corespersocket', 1))
    sockets = total_vcpus // cores_per_socket
    if sockets == 0: sockets = 1

    for key, val in vmx_data.items():
        if '.filename' in key and val.endswith('.vmdk'):
            disks.append(val)
            # Check for -flat version first, then descriptor
            flat_file = os.path.join(vmx_dir, val.replace('.vmdk', '-flat.vmdk'))
            if os.path.exists(flat_file):
                total_size += os.path.getsize(flat_file)
            elif os.path.exists(os.path.join(vmx_dir, val)):
                total_size += os.path.getsize(os.path.join(vmx_dir, val))
                
    return vmx_data, sorted(disks), total_size, sockets, cores_per_socket

def main():
    check_proxmox()
    parser = argparse.ArgumentParser(description="Migrate VMX to Proxmox QM")
    parser.add_argument("vmx_file", help="Path to the .vmx file")
    parser.add_argument("--name", help="New VM Name")
    parser.add_argument("--vmid", help="New VM ID")
    parser.add_argument("--for-real", action="store_true", help="Execute the commands")
    parser.add_argument("--modern", action="store_true", help="Use VirtIO and Q35")
    args = parser.parse_args()

    # Load Config
    with open(CONFIG_PATH, "rb") as f:
        config = tomllib.load(f)
    storage = config['proxmox'].get('default_storage', 'local-lvm')
    s_type = get_storage_type(storage)
    
    vmx_dir = os.path.dirname(os.path.abspath(args.vmx_file))
    vmx_data, disks, total_size_bytes, sockets, cores = parse_vmx(args.vmx_file)

    new_name = args.name or f"Migrated-{vmx_data.get('displayname', 'VM')}"
    vmid = args.vmid or "100"

    # Hardware Profile (Always CPU Host for Nextcloud)
    cpu_type = "host"
    if args.modern:
        net_model, scsi_ctrl, machine = "virtio", "virtio-scsi-pci", "q35"
        mode_str = "MODERN"
    else:
        net_model, scsi_ctrl, machine = "e1000", "lsi", "pc"
        mode_str = "COMPATIBILITY"
    
    commands = [
        f"qm create {vmid} --name '{new_name}' --memory {vmx_data.get('memsize', '2048')} "
        f"--sockets {sockets} --cores {cores} --cpu {cpu_type} "
        f"--net0 {net_model},bridge=vmbr0 --scsihw '{scsi_ctrl}' --machine {machine} --ostype l26"
    ]

    for i, disk in enumerate(disks):
        full_disk_path = os.path.join(vmx_dir, disk)
        # 1. Import command
        commands.append(f"qm importdisk {vmid} '{full_disk_path}' {storage}")
        
        # 2. Set/Attach command logic
        if s_type == 'directory':
            # Format required for NAS: <storage>:<vmid>/vm-<vmid>-disk-<index>.raw
            disk_volid = f"{storage}:{vmid}/vm-{vmid}-disk-{i}.raw"
        else:
            # Format for Block: <storage>:vm-<vmid>-disk-<index>
            disk_volid = f"{storage}:vm-{vmid}-disk-{i}"
            
        commands.append(f"qm set {vmid} --scsi{i} {disk_volid}")

    # Set Boot Order
    commands.append(f"qm set {vmid} --boot order=scsi0")

    print(f"\n--- Migration Plan [{mode_str}] ---")
    for cmd in commands: print(f"  {cmd}")

    if args.for_real:
        if input(f"\nProceed with migration to {storage}? (y/N): ").lower() == 'y':
            for cmd in commands:
                print(f"Executing: {cmd}")
                try:
                    subprocess.run(cmd, shell=True, check=True)
                except subprocess.CalledProcessError as e:
                    print(f"Error during execution: {e}")
                    sys.exit(1)
            print("\nMigration Complete. Verify hardware settings and start the VM.")
    else:
        print("\nReady! Use --for-real to execute.")

if __name__ == "__main__":
    main()
