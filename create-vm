#!/usr/bin/env python3
import argparse
import subprocess
import sys
import json

# --- Configuration ---
TEMPLATE_ID = "9000"
EXPECTED_SNIPPET = "local:snippets/sa-user.yaml"
DEFAULT_STORAGE = "nas-vm1"
DEFAULT_DISK = 20
DEFAULT_RAM = 2048
DEFAULT_CORES = 2

def run_command(cmd, error_msg=None, return_json=False):
    """Helper to run shell commands and exit on failure."""
    try:
        result = subprocess.run(cmd, shell=True, check=True, capture_output=True, text=True)
        if return_json:
            return json.loads(result.stdout)
        return result.stdout
    except subprocess.CalledProcessError as e:
        if error_msg:
            print(f"ERROR: {error_msg}")
            print(f"Details: {e.stderr}")
            sys.exit(1)
        return None

def check_vmid_exists(vmid):
    """Checks if a VMID is already in use using Proxmox API tools."""
    # Using json output is more reliable than grepping raw strings
    resources = run_command("pvesh get /cluster/resources --output-format json", return_json=True)
    if resources:
        for res in resources:
            if res.get('vmid') == int(vmid):
                return True, res.get('name', 'unknown')
    return False, None

def main():
    parser = argparse.ArgumentParser(description="Deploy a Proxmox VM from a validated template.")
    
    # Required Positional Arguments
    parser.add_argument("vmid", help="The ID for the new VM (e.g., 110)")
    parser.add_argument("name", help="The name for the new VM (e.g., openclaw-sandbox)")
    
    # Optional Flagged Arguments (Restored Default Strings)
    parser.add_argument("-d", "--disk", type=int, default=DEFAULT_DISK, 
                        help=f"Disk size in GB (default: {DEFAULT_DISK})")
    parser.add_argument("-r", "--ram", type=int, default=DEFAULT_RAM, 
                        help=f"RAM in MB (default: {DEFAULT_RAM})")
    parser.add_argument("-c", "--cores", type=int, default=DEFAULT_CORES, 
                        help=f"CPU cores (default: {DEFAULT_CORES})")
    parser.add_argument("-s", "--storage", default=DEFAULT_STORAGE, 
                        help=f"Target storage ID (default: {DEFAULT_STORAGE})")
    
    args = parser.parse_args()

    # 1. Check if VMID is already in use
    print(f"--- [1/5] Checking VMID {args.vmid} Availability ---")
    exists, existing_name = check_vmid_exists(args.vmid)
    if exists:
        print(f"FATAL: VMID {args.vmid} is already in use by '{existing_name}'.")
        sys.exit(1)

    # 2. Validate Template
    print(f"--- [2/5] Validating Template {TEMPLATE_ID} ---")
    config = run_command(f"qm config {TEMPLATE_ID}", "Could not read template configuration.")
    if f"user={EXPECTED_SNIPPET}" not in config:
        print(f"ERROR: Template {TEMPLATE_ID} is out of spec (missing snippet: {EXPECTED_SNIPPET})")
        sys.exit(1)

    # 3. Clone Template
    print(f"--- [3/5] Cloning to {args.storage} ---")
    run_command(f"qm clone {TEMPLATE_ID} {args.vmid} --name {args.name} --full --storage {args.storage}", 
                "Clone operation failed.")

    # 4. Specialize Hardware
    print(f"--- [4/5] Customizing: {args.cores} Cores, {args.ram}MB RAM, {args.disk}GB Disk ---")
    run_command(f"qm set {args.vmid} --cores {args.cores} --memory {args.ram} --ipconfig0 ip=dhcp --searchdomain home.teknibauer.com")
    run_command(f"qm resize {args.vmid} scsi0 {args.disk}G")

    # 5. Finalize
    print("--- [5/5] Starting VM ---")
    run_command(f"qm cloudinit update {args.vmid}")
    run_command(f"qm start {args.vmid}")

    print("-" * 50)
    print(f"Successfully deployed {args.name} ({args.vmid})")
    print(f"Storage: {args.storage} | Cores: {args.cores} | RAM: {args.ram}MB | Disk: {args.disk}GB")
    print("-" * 50)

if __name__ == "__main__":
    main()
