#!/usr/bin/env python3

import sys
import re

def parse_vmx(file_path):
    config = {}
    # Use a regex to capture key-value pairs while stripping quotes
    pattern = re.compile(r'^([\w\.:0-9]+)\s*=\s*"(.*)"')
    
    try:
        with open(file_path, 'r') as f:
            for line in f:
                match = pattern.match(line.strip())
                if match:
                    config[match.group(1)] = match.group(2)
    except FileNotFoundError:
        return "Error: File not found."

    # Calculation logic for Sockets/Cores
    total_vcpus = int(config.get('numvcpus', 1))
    cores_per_socket = int(config.get('cpuid.coresPerSocket', 1))
    sockets = total_vcpus // cores_per_socket

    # Extracting Disk Information
    disks = [val for key, val in config.items() if '.fileName' in key and val.endswith('.vmdk')]

    print(f"--- Migration Profile: {config.get('displayName', 'Unknown VM')} ---")
    print(f"CPU Sockets:      {sockets}")
    print(f"Cores per Socket: {cores_per_socket}")
    print(f"Total vCPUs:      {total_vcpus}")
    print(f"RAM (MB):         {config.get('memsize', '0')}")
    print(f"Guest OS Type:    {config.get('guestOS', 'Unknown')}")
    print(f"Firmware Mode:    {'UEFI' if config.get('firmware') == 'efi' else 'BIOS (Legacy)'}")
    print(f"SCSI Controller:  {config.get('scsi0.virtualDev', 'lsilogic')}")
    print(f"Network Adapter:  {config.get('ethernet0.virtualDev', 'e1000')}")
    print(f"Virtual Disks:    {', '.join(disks)}")
    print("-" * 40)

if __name__ == "__main__":
    if len(sys.argv) > 1:
        parse_vmx(sys.argv[1])
    else:
        print("Usage: python3 parse_vmx.py <path_to_vmx_file>")

