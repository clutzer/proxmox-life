#!/usr/bin/env python3

import sys
import re

def parse_vmx(file_path):
    config = {}
    # Captures key-value pairs; strips quotes and handles potential whitespace
    pattern = re.compile(r'^([\w\.:0-9]+)\s*=\s*"(.*)"')
    
    try:
        with open(file_path, 'r') as f:
            for line in f:
                match = pattern.match(line.strip())
                if match:
                    # Force key to lowercase for case-insensitive lookup
                    config[match.group(1).lower()] = match.group(2)
    except FileNotFoundError:
        return print(f"Error: File '{file_path}' not found.")

    # Logic using lowercase keys
    total_vcpus = int(config.get('numvcpus', 1))
    cores_per_socket = int(config.get('cpuid.corespersocket', 1))
    sockets = total_vcpus // cores_per_socket

    # Extracting Disk and Network info
    disks = [val for key, val in config.items() if '.filename' in key and val.endswith('.vmdk')]
    net_type = config.get('ethernet0.virtualdev', 'e1000')
    scsi_type = config.get('scsi0.virtualdev', 'lsilogic')

    print(f"--- Migration Profile: {config.get('displayname', 'Unknown VM')} ---")
    print(f"CPU Sockets:      {sockets}")
    print(f"Cores per Socket: {cores_per_socket}")
    print(f"Total vCPUs:      {total_vcpus}")
    print(f"RAM (MB):         {config.get('memsize', '0')}")
    print(f"Guest OS:         {config.get('guestos', 'Unknown')}")
    print(f"Firmware:         {'UEFI' if config.get('firmware') == 'efi' else 'BIOS (Legacy)'}")
    print(f"SCSI Controller:  {scsi_type}")
    print(f"Network Adapter:  {net_type}")
    print(f"Virtual Disks:    {', '.join(disks)}")
    print("-" * 45)

if __name__ == "__main__":
    if len(sys.argv) > 1:
        parse_vmx(sys.argv[1])
    else:
        print("Usage: python3 parse_vmx.py <path_to_vmx_file>")

